VITE_PUBLIC_APP_URL=http://localhost:3000
VITE_PUBLIC_BACKEND_URL=http://localhost:8787

# Postgres (local Docker compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zerodotemail"

# Supabase: the dashboard "Direct connection" host (db.<project-ref>.supabase.co) is IPv6-only.
# Many networks, Windows setups, and tools (incl. some CI) have no working IPv6 path → DNS fails with
# ENOTFOUND. Use "Session pooler" instead: Dashboard → Connect → Session pooler, copy the URI.
# Shape: postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-<REGION>.pooler.supabase.com:5432/postgres
# Append ?sslmode=require if your client complains about SSL.
# Docs: https://supabase.com/docs/guides/database/connecting-to-postgres
#
# Wrangler dev: after changing DATABASE_URL, run `pnpm nizzy sync`. It writes gitignored
# `apps/server/wrangler.local.jsonc` so Hyperdrive’s local connection matches DATABASE_URL
# (avoids “proxy request failed” on social sign-in / DB from the Worker).

# Change this to a random string, use `openssl rand -hex 32` to generate a 32 character string
BETTER_AUTH_SECRET=my-better-auth-secret
BETTER_AUTH_URL=http://localhost:3000

COOKIE_DOMAIN="localhost"

# Change to your project's client ID and secret, these work with localhost:8787
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Upstash/Local Redis Instance
REDIS_URL="http://localhost:8079"
REDIS_TOKEN="upstash-local-token"

# Resend API Key
RESEND_API_KEY=

# OpenAI API Key
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# OpenAI Model names (gpt-4o, gpt-4o-mini etc)
OPENAI_MODEL=
OPENAI_MINI_MODEL=

#AI PROMPT
AI_SYSTEM_PROMPT=""

NODE_ENV="development"

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# FOR PLAYWRIGHT E2E TESTING
PLAYWRIGHT_SESSION_TOKEN = 
PLAYWRIGHT_SESSION_DATA =
EMAIL =